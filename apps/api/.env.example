# ==========================================
# Cesto API Environment Variables
# ==========================================

# Database (Supabase now, self-hosted PostgreSQL later)
DATABASE_URL="postgresql://postgres:password@localhost:5432/cesto?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:password@localhost:5432/cesto?schema=public"

# Auth
JWT_SECRET="your-jwt-secret-min-32-chars"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cesto-media"
R2_PUBLIC_URL=""

# Redis (for caching layer)
REDIS_URL=""

# CORS
CORS_ORIGIN="http://localhost:3000"

# Notification Providers (future)
WHATSAPP_API_KEY=""
EMAIL_PROVIDER_API_KEY=""
SMS_PROVIDER_API_KEY=""

# Admin Seed
ADMIN_SEED_EMAIL="admin@cesto.in"
ADMIN_SEED_PASSWORD="admin123456"

# Server
PORT=4000
