# ============================================================
# Cesto API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.
# ============================================================

# --- Database ---
# Direct Postgres connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Auth / JWT ---
# REQUIRED in production — no fallback. Generate with: openssl rand -hex 32
JWT_SECRET=
REFRESH_TOKEN_SECRET=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Cloudflare R2 (S3-compatible storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- App ---
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# --- Admin Seed (development only) ---
# The seed script uses ADMIN_SEED_PASSWORD to create the initial admin user.
# If unset, seeding will abort to prevent unsafe defaults in production.
ADMIN_SEED_PASSWORD=
