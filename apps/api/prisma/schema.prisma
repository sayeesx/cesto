// apps/api/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// USERS & AUTH
// -----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  VENDOR
  DELIVERY_PARTNER
  SUPPORT
  CUSTOMER
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?   @unique
  passwordHash   String
  name           String?
  role           Role      @default(CUSTOMER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isActive       Boolean   @default(true)

  addresses          Address[]
  orders             Order[]
  reviews            Review[]
  reminders          Reminder[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  deliveryPartner    DeliveryPartner?
  vendor             Vendor?
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @default("HOME") // HOME, WORK, etc.
  name        String
  phone       String
  addressLine String
  area        String
  city        String
  pincode     String
  state       String
  country     String   @default("India")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  DeliveryZone DeliveryZone? @relation(fields: [pincode], references: [pincode])

  @@index([userId])
}

// -----------------------------------------------------------------------------
// CATALOG: Categories, Occasions, Relationships
// -----------------------------------------------------------------------------

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    ProductCategory[]
}

model Occasion {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  imageUrl    String?
  isActive    Boolean  @default(true)

  products    ProductOccasion[]
}

model Relationship {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  imageUrl    String?
  isActive    Boolean  @default(true)

  products    ProductRelationship[]
}

// -----------------------------------------------------------------------------
// PRODUCTS & INVENTORY
// -----------------------------------------------------------------------------

model Product {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  description         String?
  whatsInside         String?
  price               Float
  compareAtPrice      Float?
  isActive            Boolean  @default(true)
  stock               Int      @default(0)
  deliveryEstimate    String?
  sameDayAvailable    Boolean  @default(false)
  isPersonalizable    Boolean  @default(false)
  tags                String[] // Simple array of strings
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  images              ProductImage[]
  categories          ProductCategory[]
  occasions           ProductOccasion[]
  relationships       ProductRelationship[]
  orderItems          OrderItem[]
  reviews             Review[]
  vendorProducts      VendorProduct[]
  cartItems           CartItem[]
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)

  @@index([productId])
}

// Mapping Tables
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductOccasion {
  productId  String
  occasionId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  occasion   Occasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)

  @@id([productId, occasionId])
}

model ProductRelationship {
  productId      String
  relationshipId String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  relationship   Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@id([productId, relationshipId])
}

// -----------------------------------------------------------------------------
// CART & ORDERS
// -----------------------------------------------------------------------------

model Cart {
  id        String     @id @default(uuid())
  userId    String?    // Nullable for guest carts
  session   String?    @unique // Session ID for guest carts
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  variantData Json?

  @@index([cartId])
}

enum OrderStatus {
  PLACED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  FAILED
}

model Order {
  id               String       @id @default(uuid())
  orderNumber      String       @unique // e.g. CESTO-123456
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  status           OrderStatus  @default(PAYMENT_PENDING)
  totalAmount      Float
  deliveryFee      Float        @default(0)
  discount         Float        @default(0)
  finalAmount      Float

  // Recipient details
  recipientName    String
  recipientPhone   String
  deliveryAddress  Json         // Snapshot of address
  deliverySlotId   String?
  deliverySlot     DeliverySlot? @relation(fields: [deliverySlotId], references: [id], onDelete: SetNull)
  deliveryDate     DateTime
  giftMessage      String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  items            OrderItem[]
  payments         Payment[]
  refunds          Refund[]
  deliveryProof    DeliveryProof?
  vendorId         String?
  vendor           Vendor?      @relation(fields: [vendorId], references: [id])
  deliveryPartnerId String?
  deliveryPartner  DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity    Int
  priceAt     Float    // Price when ordered
  variantData Json?

  @@index([orderId])
}

// -----------------------------------------------------------------------------
// PAYMENTS & REFUNDS
// -----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(uuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  razorpayOrderId String?       @unique     
  razorpayPaymentId String?     @unique
  amount          Float
  status          PaymentStatus @default(PENDING)
  method          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Refund {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Float
  reason          String?
  status          String   @default("PENDING") // PENDING, PROCESSED, FAILED
  razorpayRefundId String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// DELIVERY
// -----------------------------------------------------------------------------

model DeliveryZone {
  id          String   @id @default(uuid())
  city        String
  area        String
  pincode     String   @unique
  isActive    Boolean  @default(true)
  minOrder    Float    @default(0)
  deliveryFee Float    @default(0)
  expressFee  Float    @default(0)
  midnightFee Float    @default(0)

  addresses   Address[]
}

model DeliverySlot {
  id          String   @id @default(uuid())
  label       String   // e.g. "10 AM - 1 PM"
  startTime   String   // "10:00"
  endTime     String   // "13:00"
  type        String   @default("STANDARD") // STANDARD, EXPRESS, MIDNIGHT
  isActive    Boolean  @default(true)
  fee         Float    @default(0)

  orders      Order[]
}

model DeliveryPartner {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType String?
  vehicleNo   String?
  isActive    Boolean  @default(true)
  
  orders      Order[]
}

model DeliveryProof {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  imageUrl    String
  notes       String?
  uploadedAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// VENDORS
// -----------------------------------------------------------------------------

model Vendor {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName   String
  address     String?
  isActive    Boolean  @default(true)

  products    VendorProduct[]
  orders      Order[]
}

model VendorProduct {
  vendorId  String
  productId String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  price     Float?
  stock     Int     @default(0)

  @@id([vendorId, productId])
}

// -----------------------------------------------------------------------------
// MARKETING & CUSTOMER SUPPORT
// -----------------------------------------------------------------------------

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discountType String  // PERCENTAGE, FIXED
  discountValue Float
  minOrderValue Float  @default(0)
  maxDiscount Float?
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean  @default(true)
  usageLimit  Int?
  usageCount  Int      @default(0)
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int      @default(5)
  comment   String?
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // e.g. "Mom's Birthday"
  date        DateTime
  relation    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CorporateEnquiry {
  id          String   @id @default(uuid())
  companyName String
  contactName String
  email       String
  phone       String
  budget      Float?
  message     String
  status      String   @default("NEW") // NEW, CONTACTED, CLOSED
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// ADMIN LOGS & SETTINGS
// -----------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // e.g. "UPDATE_ORDER_STATUS"
  entity      String   // e.g. "Order"
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())
}

model AdminSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
